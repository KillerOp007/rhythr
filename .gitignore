# Build artifacts
/target

# Copyrighted media from the local test kit — never commit to a public repo.
# The .rhr replays and the manifest are the user's own data and may be committed.
testdata/*.mp3
testdata/*_cover.png

# Rendered output (contains copyrighted song audio).
/renders

# Tauri build-generated permission schemas (regenerated by tauri-build).
/crates/gui/gen

# Bundled Windows ffmpeg (downloaded at build time, GPL — ships in the installer, not the repo).
/crates/gui/ffmpeg.exe
/crates/gui/ffmpeg-LICENSE.txt

# Comment-stripped frontend generated by crates/gui/build.rs at build time.
/crates/gui/ui-dist
/crates/gui/README.txt

# Internal working notes — not part of the published project.
/notes
/.cargo/config.toml
/crates/gui/FONT-LICENSE.txt
