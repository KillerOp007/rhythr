{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rhythr",
  "version": "0.3.4",
  "identifier": "com.killerop.rhythr",
  "build": {
    "frontendDist": "ui-dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "rhythr",
        "width": 1380,
        "height": 880,
        "minWidth": 1120,
        "minHeight": 720,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "resources": [
      "README.txt",
      "FONT-LICENSE.txt"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "rhr"
        ],
        "name": "Rhythia Replay",
        "description": "Rhythia replay file",
        "role": "Viewer",
        "mimeType": "application/x-rhythia-replay"
      }
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "publisher": "killerop",
    "copyright": "Copyright (c) 2026 killerop. MIT license. Bundles ffmpeg (GPL, separate process).",
    "shortDescription": "Render Rhythia replays to video",
    "longDescription": "rhythr is an unofficial community tool that renders Rhythia (.rhr) replays into videos that look exactly like the game, using your own skin config. Read-only: replays are never modified. Not affiliated with Rhythia or Capo Games.",
    "homepage": "https://github.com/KillerOp007/rhythr",
    "linux": {
      "deb": {
        "depends": [
          "ffmpeg"
        ],
        "files": {
          "/usr/share/mime/packages/rhythr.xml": "../../packaging/linux/rhythr-mime.xml"
        },
        "desktopTemplate": "../../packaging/linux/rhythr.desktop"
      },
      "rpm": {
        "files": {
          "/usr/share/mime/packages/rhythr.xml": "../../packaging/linux/rhythr-mime.xml"
        },
        "desktopTemplate": "../../packaging/linux/rhythr.desktop"
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgyNzQ5OEIxMjM4RDlFMkUKUldRdW5vMGpzWmgwZ2dzbkNFMDFHUjVhOVdTL3ZuZTExZiszaTkzUUVxVnBTS1hxMENjUTVPcHoK",
      "endpoints": [
        "https://github.com/KillerOp007/rhythr/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
