# Build environment for the Linux packages. Ubuntu 22.04 on purpose: the
# produced binaries inherit its glibc 2.35 baseline, so the AppImage/deb/
# rpm run on any mainstream distro from 2022 onward. (Older is not
# possible — Tauri 2 needs webkit2gtk-4.1, which first shipped in 22.04.)
FROM docker.io/library/ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential curl wget file pkg-config ca-certificates git \
    libwebkit2gtk-4.1-dev libgtk-3-dev librsvg2-dev \
    libayatana-appindicator3-dev libssl-dev libxdo-dev \
    patchelf desktop-file-utils xdg-utils xz-utils squashfs-tools \
    && rm -rf /var/lib/apt/lists/*

RUN curl -sSf https://sh.rustup.rs | sh -s -- -y --profile minimal --default-toolchain stable
ENV PATH=/root/.cargo/bin:$PATH

# Tauri CLI baked into the image so container runs start instantly.
RUN cargo install tauri-cli --version '^2' --locked && cargo-tauri --version
